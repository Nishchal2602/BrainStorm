# Copy to .env and fill in. These are read at BUILD time via import.meta.env and
# baked into the extension bundle. Backend precedence: Gemini → proxy → BYOK.

# --- Gemini mode (MVP / validation) -----------------------------------------
# Simplest path: paste your Google Gemini API key here and rebuild. The extension
# then calls Gemini directly for every action (the UI model picker is ignored).
# Get a key at https://aistudio.google.com/apikey
# NOTE: this key is baked into the bundle (extractable by anyone who installs the
# unpacked extension). That's acceptable for free-tier Gemini validation; for
# wider distribution put the key behind the proxy instead. Keep .env out of git
# (it already is) and set a usage cap in Google AI Studio / Cloud as a backstop.
VITE_GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash).
VITE_GEMINI_MODEL=gemini-2.5-flash

# --- Owner-key proxy mode (Anthropic via Cloudflare Worker) ------------------
# Used only when VITE_GEMINI_API_KEY is empty. See proxy/README.md.
# The deployed Worker URL.
VITE_PROXY_URL=https://pm-copilot-proxy.<your-subdomain>.workers.dev

# Must match the Worker's PROXY_SHARED_SECRET. Note: this value ships in the
# extension bundle (it only deters casual abuse — the Worker's daily cap is the
# real spend guard).
VITE_PROXY_SECRET=change-me

# If both are left empty, the extension falls back to BYOK (user enters their own
# Anthropic key in Settings) — useful for local development.

# Demo mode: features return sample outputs with NO API call (manual UI testing).
# Optional — you can also toggle demo from the first screen / Settings without a rebuild.
VITE_DEMO_MODE=false
